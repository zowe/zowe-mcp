# Zowe Artifactory npm registry (zowex-sdk, @zowe/*)
# See https://zowe.jfrog.io/artifactory/npm-release/
registry=https://zowe.jfrog.io/artifactory/api/npm/npm-release/

# Disable hoisting: keep dependencies nested under each package's node_modules
# This prevents version conflicts (e.g. ajv@6 vs ajv@8) and simplifies bundling
install-strategy=nested
