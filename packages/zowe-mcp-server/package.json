{
  "name": "@zowe/mcp-server",
  "version": "0.9.0-dev",
  "description": "Zowe MCP Server - Model Context Protocol server providing tools for z/OS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "zowe-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-resources.cjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:native-stdio-e2e": "npm run build && ZOWE_MCP_RUN_NATIVE_STDIO_E2E=1 vitest run native-stdio.e2e",
    "test:keycloak-jwt-e2e": "npm run build && ZOWE_MCP_KEYCLOAK_E2E=1 vitest run keycloak-http-jwt.e2e",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,jsonc}\"",
    "check-format": "prettier --check \"**/*.{ts,js,mjs,json,jsonc}\"",
    "test:airgap": "bash scripts/test-airgap-install.sh",
    "test:airgap:build": "bash scripts/test-airgap-install.sh --build",
    "test:airgap:build:native": "bash scripts/test-airgap-install.sh --build --native",
    "prepack": "node scripts/bundle-for-pack.cjs",
    "postpack": "node scripts/restore-after-pack.cjs"
  },
  "keywords": [
    "zowe",
    "mcp",
    "model-context-protocol",
    "z/OS",
    "mainframe"
  ],
  "license": "EPL-2.0",
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@zowe/imperative": "^8.30.1",
    "@zowe/zos-uss-for-zowe-sdk": "^8.11.0",
    "express": "^5.1.0",
    "hardstop-patterns": "^1.0.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^11.2.6",
    "node-ssh": "^13.2.0",
    "path-to-regexp": "8.4.0",
    "yargs": "^17.7.2",
    "zod": "^4.3.6",
    "zowe-mcp-common": "*",
    "zowex-sdk": "file:../../resources/zowex-sdk-0.4.0.tgz"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.5",
    "ssh2": "^1.17.0",
    "vitest": "^4.0.18"
  }
}
