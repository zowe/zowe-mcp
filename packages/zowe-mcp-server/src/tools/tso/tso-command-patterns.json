{"dangerous":[{"id":"tso-password","message":"PASSWORD changes TSO password.","pattern":"\\bPASS(?:WORD)?\\b"},{"id":"tso-call","message":"CALL runs programs (arbitrary execution).","pattern":"\\bCALL\\b"},{"id":"tso-profile","message":"PROFILE changes session settings.","pattern":"\\bPROF(?:ILE)?\\b"},{"id":"tso-alter","message":"ALTER changes VSAM or catalog entries.","pattern":"\\bALTER\\b"},{"id":"tso-oshell","message":"OSHELL runs arbitrary USS commands (fails with rc 255 in ZNP).","pattern":"\\bOSHELL\\b"},{"id":"tso-delete-system","message":"Deleting system datasets (SYS1, SYSL, SYS2) is not allowed.","pattern":"\\b(DEL(?:ETE)?|DEL)\\b.*\\b(SYS1|SYSL|SYS2)\\b"},{"id":"tso-rename-system","message":"Renaming system datasets (SYS1, SYSL, SYS2) is not allowed.","pattern":"\\b(REN(?:AME)?|REN)\\b.*\\b(SYS1|SYSL|SYS2)\\b"}],"elicit":[{"id":"tso-delete","message":"DELETE permanently removes datasets or members; user approval required.","pattern":"\\b(DEL(?:ETE)?|DEL)\\b"},{"id":"tso-rename","message":"RENAME modifies dataset or member names; user approval required.","pattern":"\\b(REN(?:AME)?|REN)\\b"},{"id":"tso-submit","message":"SUBMIT submits jobs; user approval required.","pattern":"\\bSUBMIT\\b"}],"safe":[{"id":"tso-listds","pattern":"\\b(LISTDS|LISTD)\\b"},{"id":"tso-listalc","pattern":"\\b(LISTALC|LISTA)\\b"},{"id":"tso-listcat","pattern":"\\b(LISTCAT|LISTC)\\b"},{"id":"tso-listbc","pattern":"\\bLISTBC\\b"},{"id":"tso-status","pattern":"\\bSTATUS\\b"},{"id":"tso-help","pattern":"\\b(HELP|H)\\b"},{"id":"tso-who","pattern":"\\bWHO\\b"},{"id":"tso-time","pattern":"\\bTIME\\b"},{"id":"tso-system","pattern":"\\bSYSTEM\\b"}]}