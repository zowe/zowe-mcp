{
  "$schema": "vscode://schemas/color-theme",
  "name": "Broadcom Dark (Cobalt Blue)",
  "type": "dark",
  "colors": {
    "editor.background": "#1B1D36",
    "editor.foreground": "#EEEEEE",
    "activityBar.background": "#16182e",
    "activityBar.foreground": "#EEEEEE",
    "activityBar.inactiveForeground": "#53565A",
    "activityBarBadge.background": "#0098C7",
    "activityBarBadge.foreground": "#FFFFFF",
    "sideBar.background": "#252840",
    "sideBar.foreground": "#EEEEEE",
    "sideBarTitle.foreground": "#53565A",
    "sideBarSectionHeader.background": "#252840",
    "sideBarSectionHeader.foreground": "#EEEEEE",
    "titleBar.activeBackground": "#1B1D36",
    "titleBar.activeForeground": "#EEEEEE",
    "titleBar.inactiveBackground": "#252840",
    "titleBar.inactiveForeground": "#53565A",
    "statusBar.background": "#0098C7",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.noFolderBackground": "#1B1D36",
    "statusBar.noFolderForeground": "#EEEEEE",
    "statusBarItem.hoverBackground": "#007B8C",
    "statusBarItem.remoteBackground": "#007741",
    "statusBarItem.remoteForeground": "#FFFFFF",
    "tab.activeBackground": "#1B1D36",
    "tab.activeForeground": "#EEEEEE",
    "tab.inactiveBackground": "#252840",
    "tab.inactiveForeground": "#53565A",
    "tab.border": "#252840",
    "tab.activeBorder": "#0098C7",
    "tab.activeModifiedBorder": "#0098C7",
    "editorGroupHeader.tabsBackground": "#252840",
    "editorGroup.border": "#3d4060",
    "panel.background": "#252840",
    "panel.border": "#3d4060",
    "panelTitle.activeBorder": "#0098C7",
    "panelTitle.activeForeground": "#EEEEEE",
    "panelTitle.inactiveForeground": "#53565A",
    "focusBorder": "#0098C7",
    "foreground": "#EEEEEE",
    "descriptionForeground": "#53565A",
    "selection.background": "#0098C740",
    "input.background": "#1B1D36",
    "input.foreground": "#EEEEEE",
    "input.border": "#3d4060",
    "input.placeholderForeground": "#6C4B94",
    "inputOption.activeBorder": "#0098C7",
    "inputOption.activeBackground": "#252840",
    "button.background": "#0098C7",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#007B8C",
    "dropdown.background": "#1B1D36",
    "dropdown.foreground": "#EEEEEE",
    "dropdown.border": "#3d4060",
    "list.activeSelectionBackground": "#0098C740",
    "list.activeSelectionForeground": "#EEEEEE",
    "list.hoverBackground": "#252840",
    "list.focusBackground": "#1B1D36",
    "list.inactiveSelectionBackground": "#252840",
    "list.dropBackground": "#6C4B9420",
    "list.highlightForeground": "#2ebeef",
    "menu.background": "#252840",
    "menu.foreground": "#EEEEEE",
    "menu.selectionBackground": "#0098C740",
    "menu.selectionForeground": "#EEEEEE",
    "menubar.selectionForeground": "#0098C7",
    "scrollbarSlider.background": "#3d406080",
    "scrollbarSlider.hoverBackground": "#53565A80",
    "scrollbarSlider.activeBackground": "#6C4B9480",
    "badge.background": "#0098C7",
    "badge.foreground": "#FFFFFF",
    "progressBar.background": "#0098C7",
    "editorCursor.foreground": "#0098C7",
    "editor.lineHighlightBackground": "#252840",
    "editor.selectionBackground": "#0098C740",
    "editor.inactiveSelectionBackground": "#6C4B9420",
    "editor.selectionHighlightBackground": "#6C4B9420",
    "editorIndentGuide.background1": "#3d4060",
    "editorIndentGuide.activeBackground1": "#53565A",
    "widget.border": "#3d4060",
    "errorForeground": "#CC092F",
    "textLink.foreground": "#2ebeef",
    "textLink.activeForeground": "#00c6c2"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "variable.legacy.builtin.python"],
      "settings": { "foreground": "#EEEEEE" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "comment", "settings": { "foreground": "#53565A" } },
    { "scope": "constant.language", "settings": { "foreground": "#0098C7" } },
    {
      "scope": ["constant.numeric", "variable.other.enummember"],
      "settings": { "foreground": "#61A60E" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#00a5ae" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#0098C7" } },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.less"],
      "settings": { "foreground": "#2ebeef" }
    },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#00c6c2" } },
    { "scope": "invalid", "settings": { "foreground": "#CC092F" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold", "foreground": "#0098C7" } },
    { "scope": "markup.heading", "settings": { "fontStyle": "bold", "foreground": "#0098C7" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic", "foreground": "#2ebeef" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#007741" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#CC092F" } },
    { "scope": "markup.changed", "settings": { "foreground": "#0098C7" } },
    { "scope": "storage", "settings": { "foreground": "#6C4B94" } },
    { "scope": "storage.type", "settings": { "foreground": "#6C4B94" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#6C4B94" } },
    { "scope": ["string", "meta.embedded.assembly"], "settings": { "foreground": "#2ebeef" } },
    { "scope": "string.regexp", "settings": { "foreground": "#00a5ae" } },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#0098C7" }
    },
    {
      "scope": ["support.type.property-name", "support.type.vendored.property-name"],
      "settings": { "foreground": "#00c6c2" }
    },
    { "scope": "keyword", "settings": { "foreground": "#0098C7" } },
    { "scope": "keyword.control", "settings": { "foreground": "#0098C7" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#EEEEEE" } },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#0098C7" }
    },
    { "scope": "variable.language", "settings": { "foreground": "#6C4B94" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#53565A" } },
    { "scope": "meta.preprocessor", "settings": { "foreground": "#0098C7" } },
    { "scope": "meta.diff.header", "settings": { "foreground": "#0098C7" } }
  ],
  "semanticHighlighting": true
}
