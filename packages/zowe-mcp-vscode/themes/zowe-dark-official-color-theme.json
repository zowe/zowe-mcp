{
  "$schema": "vscode://schemas/color-theme",
  "name": "Zowe Dark (Official)",
  "type": "dark",
  "colors": {
    "editor.background": "#252628",
    "editor.foreground": "#f3f4f4",
    "activityBar.background": "#1b375f",
    "activityBar.foreground": "#f3f4f4",
    "activityBar.inactiveForeground": "#858990",
    "activityBarBadge.background": "#3975d0",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#3d3f42",
    "sideBar.foreground": "#f3f4f4",
    "sideBarTitle.foreground": "#858990",
    "sideBarSectionHeader.background": "#3d3f42",
    "sideBarSectionHeader.foreground": "#f3f4f4",
    "titleBar.activeBackground": "#252628",
    "titleBar.activeForeground": "#f3f4f4",
    "titleBar.inactiveBackground": "#3d3f42",
    "titleBar.inactiveForeground": "#858990",
    "statusBar.background": "#3975d0",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#252628",
    "statusBar.noFolderForeground": "#f3f4f4",
    "statusBarItem.hoverBackground": "#3162ac",
    "statusBarItem.remoteBackground": "#16825d",
    "statusBarItem.remoteForeground": "#ffffff",
    "tab.activeBackground": "#252628",
    "tab.activeForeground": "#f3f4f4",
    "tab.inactiveBackground": "#3d3f42",
    "tab.inactiveForeground": "#858990",
    "tab.border": "#3d3f42",
    "tab.activeBorder": "#3975d0",
    "tab.activeModifiedBorder": "#3975d0",
    "editorGroupHeader.tabsBackground": "#3d3f42",
    "editorGroup.border": "#55585c",
    "panel.background": "#3d3f42",
    "panel.border": "#55585c",
    "panelTitle.activeBorder": "#3975d0",
    "panelTitle.activeForeground": "#f3f4f4",
    "panelTitle.inactiveForeground": "#858990",
    "focusBorder": "#3975d0",
    "foreground": "#f3f4f4",
    "descriptionForeground": "#858990",
    "selection.background": "#1b375f80",
    "input.background": "#252628",
    "input.foreground": "#f3f4f4",
    "input.border": "#55585c",
    "input.placeholderForeground": "#9b9ea4",
    "inputOption.activeBorder": "#3975d0",
    "inputOption.activeBackground": "#1b375f",
    "button.background": "#3975d0",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#3162ac",
    "dropdown.background": "#252628",
    "dropdown.foreground": "#f3f4f4",
    "dropdown.border": "#55585c",
    "list.activeSelectionBackground": "#1b375f",
    "list.activeSelectionForeground": "#f3f4f4",
    "list.hoverBackground": "#3d3f42",
    "list.focusBackground": "#252628",
    "list.inactiveSelectionBackground": "#3d3f42",
    "list.dropBackground": "#264c8640",
    "list.highlightForeground": "#5e8fd9",
    "menu.background": "#3d3f42",
    "menu.foreground": "#f3f4f4",
    "menu.selectionBackground": "#1b375f",
    "menu.selectionForeground": "#f3f4f4",
    "menubar.selectionForeground": "#3975d0",
    "scrollbarSlider.background": "#55585c80",
    "scrollbarSlider.hoverBackground": "#6d717680",
    "scrollbarSlider.activeBackground": "#85899080",
    "badge.background": "#3975d0",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#3975d0",
    "editorCursor.foreground": "#3975d0",
    "editor.lineHighlightBackground": "#3d3f42",
    "editor.selectionBackground": "#1b375f80",
    "editor.inactiveSelectionBackground": "#264c8640",
    "editor.selectionHighlightBackground": "#264c8640",
    "editorIndentGuide.background1": "#55585c",
    "editorIndentGuide.activeBackground1": "#6d7176",
    "widget.border": "#55585c",
    "errorForeground": "#e0182d",
    "textLink.foreground": "#5e8fd9",
    "textLink.activeForeground": "#82a8e1"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "variable.legacy.builtin.python"],
      "settings": { "foreground": "#f3f4f4" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "comment", "settings": { "foreground": "#858990" } },
    { "scope": "constant.language", "settings": { "foreground": "#3975d0" } },
    {
      "scope": ["constant.numeric", "variable.other.enummember"],
      "settings": { "foreground": "#82a8e1" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#3b77d1" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#3975d0" } },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.less"],
      "settings": { "foreground": "#5e8fd9" }
    },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#82a8e1" } },
    { "scope": "invalid", "settings": { "foreground": "#e0182d" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold", "foreground": "#3975d0" } },
    { "scope": "markup.heading", "settings": { "fontStyle": "bold", "foreground": "#3975d0" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic", "foreground": "#5e8fd9" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#97cf46" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#e0182d" } },
    { "scope": "markup.changed", "settings": { "foreground": "#3975d0" } },
    { "scope": "storage", "settings": { "foreground": "#3975d0" } },
    { "scope": "storage.type", "settings": { "foreground": "#3975d0" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#3975d0" } },
    { "scope": ["string", "meta.embedded.assembly"], "settings": { "foreground": "#82a8e1" } },
    { "scope": "string.regexp", "settings": { "foreground": "#3b77d1" } },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#3975d0" }
    },
    {
      "scope": ["support.type.property-name", "support.type.vendored.property-name"],
      "settings": { "foreground": "#82a8e1" }
    },
    { "scope": "keyword", "settings": { "foreground": "#3975d0" } },
    { "scope": "keyword.control", "settings": { "foreground": "#3975d0" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#f3f4f4" } },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#3975d0" }
    },
    { "scope": "variable.language", "settings": { "foreground": "#3975d0" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#6d7176" } },
    { "scope": "meta.preprocessor", "settings": { "foreground": "#3975d0" } },
    { "scope": "meta.diff.header", "settings": { "foreground": "#3975d0" } }
  ],
  "semanticHighlighting": true
}
