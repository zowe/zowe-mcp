{
  "$schema": "vscode://schemas/color-theme",
  "name": "Zowe Light (Official)",
  "type": "light",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#0d0d0e",
    "activityBar.background": "#f3f4f4",
    "activityBar.foreground": "#0d0d0e",
    "activityBar.inactiveForeground": "#6d7176",
    "activityBarBadge.background": "#3162ac",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#f3f4f4",
    "sideBar.foreground": "#0d0d0e",
    "sideBarTitle.foreground": "#6d7176",
    "sideBarSectionHeader.background": "#f3f4f4",
    "sideBarSectionHeader.foreground": "#0d0d0e",
    "titleBar.activeBackground": "#ffffff",
    "titleBar.activeForeground": "#0d0d0e",
    "titleBar.inactiveBackground": "#f3f4f4",
    "titleBar.inactiveForeground": "#6d7176",
    "statusBar.background": "#3162ac",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#f3f4f4",
    "statusBar.noFolderForeground": "#0d0d0e",
    "statusBarItem.hoverBackground": "#264c86",
    "statusBarItem.remoteBackground": "#16825d",
    "statusBarItem.remoteForeground": "#ffffff",
    "tab.activeBackground": "#ffffff",
    "tab.activeForeground": "#0d0d0e",
    "tab.inactiveBackground": "#f3f4f4",
    "tab.inactiveForeground": "#6d7176",
    "tab.border": "#dddee0",
    "tab.activeBorder": "#3162ac",
    "tab.activeModifiedBorder": "#3162ac",
    "editorGroupHeader.tabsBackground": "#f3f4f4",
    "editorGroup.border": "#dddee0",
    "panel.background": "#f3f4f4",
    "panel.border": "#c7c9cc",
    "panelTitle.activeBorder": "#3162ac",
    "panelTitle.activeForeground": "#0d0d0e",
    "panelTitle.inactiveForeground": "#6d7176",
    "focusBorder": "#3162ac",
    "foreground": "#0d0d0e",
    "descriptionForeground": "#6d7176",
    "selection.background": "#c9d9f240",
    "input.background": "#ffffff",
    "input.foreground": "#0d0d0e",
    "input.border": "#c7c9cc",
    "input.placeholderForeground": "#9b9ea4",
    "inputOption.activeBorder": "#3162ac",
    "inputOption.activeBackground": "#edf2fa",
    "button.background": "#3162ac",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#264c86",
    "dropdown.background": "#ffffff",
    "dropdown.foreground": "#0d0d0e",
    "dropdown.border": "#c7c9cc",
    "list.activeSelectionBackground": "#c9d9f2",
    "list.activeSelectionForeground": "#0d0d0e",
    "list.hoverBackground": "#dddee0",
    "list.focusBackground": "#f3f4f4",
    "list.inactiveSelectionBackground": "#f3f4f4",
    "list.dropBackground": "#edf2fa",
    "list.highlightForeground": "#3162ac",
    "menu.background": "#ffffff",
    "menu.foreground": "#0d0d0e",
    "menu.selectionBackground": "#c9d9f2",
    "menu.selectionForeground": "#0d0d0e",
    "menubar.selectionForeground": "#3162ac",
    "scrollbarSlider.background": "#9b9ea460",
    "scrollbarSlider.hoverBackground": "#6d717660",
    "scrollbarSlider.activeBackground": "#55585c60",
    "badge.background": "#3162ac",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#3162ac",
    "editorCursor.foreground": "#3162ac",
    "editor.lineHighlightBackground": "#f3f4f4",
    "editor.selectionBackground": "#c9d9f240",
    "editor.inactiveSelectionBackground": "#edf2fa",
    "editor.selectionHighlightBackground": "#edf2fa",
    "editorIndentGuide.background1": "#dddee0",
    "editorIndentGuide.activeBackground1": "#c7c9cc",
    "widget.border": "#c7c9cc",
    "errorForeground": "#e0182d",
    "textLink.foreground": "#3162ac",
    "textLink.activeForeground": "#264c86"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "variable.legacy.builtin.python"],
      "settings": { "foreground": "#0d0d0e" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "comment", "settings": { "foreground": "#6d7176" } },
    { "scope": "constant.language", "settings": { "foreground": "#3162ac" } },
    {
      "scope": ["constant.numeric", "variable.other.enummember"],
      "settings": { "foreground": "#1b375f" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#3b77d1" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#3162ac" } },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.less"],
      "settings": { "foreground": "#264c86" }
    },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#1b375f" } },
    { "scope": "invalid", "settings": { "foreground": "#e0182d" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold", "foreground": "#3162ac" } },
    { "scope": "markup.heading", "settings": { "fontStyle": "bold", "foreground": "#3162ac" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic", "foreground": "#264c86" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#97cf46" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#e0182d" } },
    { "scope": "markup.changed", "settings": { "foreground": "#3162ac" } },
    { "scope": "storage", "settings": { "foreground": "#3162ac" } },
    { "scope": "storage.type", "settings": { "foreground": "#3162ac" } },
    { "scope": "storage.modifier", "settings": { "foreground": "#3162ac" } },
    { "scope": ["string", "meta.embedded.assembly"], "settings": { "foreground": "#1b375f" } },
    { "scope": "string.regexp", "settings": { "foreground": "#264c86" } },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#3162ac" }
    },
    {
      "scope": ["support.type.property-name", "support.type.vendored.property-name"],
      "settings": { "foreground": "#1b375f" }
    },
    { "scope": "keyword", "settings": { "foreground": "#3162ac" } },
    { "scope": "keyword.control", "settings": { "foreground": "#3162ac" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#0d0d0e" } },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#3162ac" }
    },
    { "scope": "variable.language", "settings": { "foreground": "#3162ac" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#6d7176" } },
    { "scope": "meta.preprocessor", "settings": { "foreground": "#3162ac" } },
    { "scope": "meta.diff.header", "settings": { "foreground": "#3162ac" } }
  ],
  "semanticHighlighting": true
}
